# TMDB (client-exposed, used by the Vite frontend)
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Gemini (server-side only, used for AI recommendations)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# MySQL database
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_DATABASE=your_db_name
MYSQL_CONNECTION_LIMIT=10

# Auth
JWT_SECRET=replace_with_a_long_random_string

# Server (production only — Hostinger's Node.js app manager sets PORT itself;
# leave unset for local dev, where it defaults to 5001)
# PORT=5001
# CORS_ORIGIN=https://yourdomain.com
